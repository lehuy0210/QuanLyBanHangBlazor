@page "/Product/Edit/{Id:int}"
@using QLBH.DTO
@using QLBH.WEB.Services
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<div class="mb-4">
    <h2>Cập nhật sản phẩm</h2>
</div>

@if (editProduct == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải dữ liệu...</span>
        </div>
        <p class="mt-2">Đang tải thông tin sản phẩm...</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="editProduct" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="editProduct.Name" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                        <InputNumber class="form-control" @bind-Value="editProduct.Price" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Quy cách <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="editProduct.Quantity" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Số lượng tồn kho <span class="text-danger">*</span></label>
                        <InputNumber class="form-control" @bind-Value="editProduct.UnitsInStock" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Loại hàng hóa: <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="editProduct.CateId" TValue="int">
                            <option value="0">-- Select Category --</option>
                            @if (categories != null)
                            {
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            }
                        </InputSelect>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nhà cung cấp: <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="editProduct.SupId" TValue="int">
                            <option value="0">-- Select Supplier --</option>
                            @if (suppliers != null)
                            {
                                @foreach (var sup in suppliers)
                                {
                                    <option value="@sup.Id">@sup.Name</option>
                                }
                            }
                        </InputSelect>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="mt-3">
                    <button type="submit" class="btn btn-warning px-4">Lưu thay đổi</button>
                    <a href="/products" class="btn btn-secondary px-4 ms-2">Hủy bỏ</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ProductDTO editProduct;
    private string errorMessage = "";

    private List<CategoryDTO> categories = new List<CategoryDTO>();
    private List<SupplierDTO> suppliers = new List<SupplierDTO>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await ProductService.GetCategoriesAsync();
            suppliers = await ProductService.GetSuppliersAsync();

            editProduct = await ProductService.GetProductByIdAsync(Id);

            if (editProduct == null)
            {
                errorMessage = "Không tìm thấy sản phẩm này trong cơ sở dữ liệu.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi khi tải dữ liệu: " + ex.Message;
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (editProduct.CateId == 0 || editProduct.SupId == 0)
            {
                errorMessage = "Vui lòng chọn Loại hàng hóa và Nhà cung cấp!";
                return;
            }

            bool isSuccess = await ProductService.UpdateProductAsync(Id, editProduct);

            if (isSuccess)
            {
                NavigationManager.NavigateTo("/products");
            }
            else
            {
                errorMessage = "Có lỗi xảy ra khi cập nhật. Vui lòng thử lại!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi kết nối API: " + ex.Message;
        }
    }
}