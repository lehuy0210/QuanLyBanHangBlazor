@page "/Product/Create"
@using QLBH.DTO
@using QLBH.WEB.Services
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<div class="mb-4">
    <h2>Thêm sản phẩm mới</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <EditForm Model="newProduct" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="newProduct.Name" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                    <InputNumber class="form-control" @bind-Value="newProduct.Price" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Quy cách <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="newProduct.Quantity" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Số lượng tồn kho <span class="text-danger">*</span></label>
                    <InputNumber class="form-control" @bind-Value="newProduct.UnitsInStock" required />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Loại hàng hóa: <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="newProduct.CateId" TValue="int">
                        <option value="0">-- Select Category --</option>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => newProduct.CateId)" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Nhà cung cấp: <span class="text-danger">*</span></label>
                    <InputSelect class="form-select" @bind-Value="newProduct.SupId" TValue="int">
                        <option value="0">-- Select Supplier --</option>
                        @if (suppliers != null)
                        {
                            @foreach (var sup in suppliers)
                            {
                                <option value="@sup.Id">@sup.Name</option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage For="@(() => newProduct.SupId)" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="mt-3">
                <button type="submit" class="btn btn-primary px-4">Lưu dữ liệu</button>
                <a href="/products" class="btn btn-secondary px-4 ms-2">Hủy bỏ</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private ProductDTO newProduct = new ProductDTO();
    private string errorMessage = "";

    private List<CategoryDTO> categories = new List<CategoryDTO>();
    private List<SupplierDTO> suppliers = new List<SupplierDTO>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await ProductService.GetCategoriesAsync();
            suppliers = await ProductService.GetSuppliersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi khi tải danh mục: " + ex.Message;
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            if (newProduct.CateId == 0 || newProduct.SupId == 0)
            {
                errorMessage = "Vui lòng chọn Loại hàng hóa và Nhà cung cấp!";
                return;
            }

            bool isSuccess = await ProductService.CreateProductAsync(newProduct);

            if (isSuccess)
            {
                NavigationManager.NavigateTo("/products");
            }
            else
            {
                errorMessage = "Có lỗi xảy ra khi lưu vào cơ sở dữ liệu. Vui lòng thử lại!";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Lỗi kết nối API: " + ex.Message;
        }
    }
}